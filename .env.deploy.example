# Skopiuj ten plik do .env.deploy i uzupełnij swoimi danymi.
# .env.deploy jest w .gitignore — nigdy nie trafi do repozytorium/gita.

# Adres serwera FTP (bez ftp:// — sam host/IP)
FTP_HOST=82.198.227.87

# Login FTP (u Hostingera zwykle pełna nazwa konta, np. uXXXXXXXX.twojadomena.com)
FTP_USER=

# Hasło FTP
FTP_PASSWORD=

# Opcjonalnie — port FTP (domyślnie 21)
# FTP_PORT=21

# Opcjonalnie — użyj FTPS (szyfrowane FTP), jeśli hosting tego wymaga/wspiera
# FTP_SECURE=true

# Katalog na serwerze, do którego wgrywana jest zawartość dist/
# Dla głównej domeny na Hostingerze to zwykle /public_html
FTP_REMOTE_DIR=/public_html
